{
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(brew install:*)",
      "Bash(yarn add:*)",
      "Bash(yarn install:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(cargo install:*)",
      "Bash(gem install:*)",
      "Bash(go install:*)",
      "Bash(apt install:*)",
      "Bash(apt-get install:*)"
    ],
    "ask": [
      "Bash(git rebase:*)"
    ]
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "figma@claude-plugins-official": true
  },
  "sandbox": {
    "excludedCommands": [
      "gh *"
    ]
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
