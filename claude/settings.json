{
  "model": "opus[1m]",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "allow": ["Bash"],
    "ask": ["Bash(git rebase:*)"],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(brew install:*)",
      "Bash(yarn add:*)",
      "Bash(yarn install:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(cargo install:*)",
      "Bash(gem install:*)",
      "Bash(go install:*)",
      "Bash(apt install:*)",
      "Bash(apt-get install:*)"
    ]
  }
}
